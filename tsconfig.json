{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@services/*":   ["./src/services/*"],
      "@viewmodels/*": ["./src/viewmodels/*"],
      "@views/*":      ["./src/views/*"],
      "@components/*": ["./src/views/components/*"],
      "@screens/*":    ["./src/views/screens/*"],
      "@models/*":     ["./src/models/*"],
      "@store/*":      ["./src/store/*"],
      "@theme/*":      ["./src/theme/*"],
      "@navigation/*": ["./src/navigation/*"],
      "@constants/*":  ["./src/constants/*"],
      "@hooks/*":      ["./src/hooks/*"],
      "@utils/*":      ["./src/utils/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
